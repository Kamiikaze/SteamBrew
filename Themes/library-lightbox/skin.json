{
  "name": "Steam-Library Lightbox Images",
  "description": "A theme which adds a lightbox for images in Steam-Library News posts.",
  "author": "Kamikaze",
  "version": "1.0.1",
  "tags": ["Library", "Lightbox", "JS"],
  "github": {
    "owner": "Kamiikaze",
    "repo_name": "https://github.com/Kamiikaze/SteamBrew"
  },
  "Patches": [
    {
      "MatchRegexString": "^Steam$",
      "TargetCss": "src/css/styles.css",
      "TargetJs": "src/js/script.js"
    }
  ]
}
